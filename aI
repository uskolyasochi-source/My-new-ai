    def _log(self, sender: str, msg: str, tag: str = None):
        self.chat_log.config(state='normal')
        ts = datetime.now().strftime("%H:%M:%S")
        self.chat_log.insert('end', f"[{ts}] {sender}: {msg}\n", tag or ("user" if sender == "Ты" else "ai" if sender == "ИИ" else "sys"))
        self.chat_log.see('end')
        self.chat_log.config(state='disabled')
    
    def _send(self):
        text = self.msg_ent.get().strip()
        if not text: return
        self.msg_ent.delete(0, 'end')
        self._log("Ты", text, "user")
        
        # Проверка kill.os
        if text.lower() == "kill.os":
            self._trigger_red_alert()
            return
        
        response = self.brain.get_response(text)
        self._log("ИИ", response, "ai")
        self.brain.add_context(text, response)
    
    def _train(self):
        kw, ans = self.kw_ent.get(), self.ans_ent.get()
        if kw and ans and self.brain.train(kw, ans):
            messagebox.showinfo("Успех", "Фраза добавлена в базу знаний! 🎉")
            self.kw_ent.delete(0, 'end')
            self.ans_ent.delete(0, 'end')
        else:
            messagebox.showwarning("Ошибка", "Заполни оба поля!")
    
    def _clear_context(self):
        if messagebox.askyesno("Подтверждение", "Очистить память контекста?"):
            self.brain.clear_context()
            self._log("СИСТЕМА", "Контекст очищен", "sys")
    
    def _reload_brain(self):
        self.brain = MultiAIBrain()
        self._log("СИСТЕМА", "База знаний перезапущена", "sys")
    
    def _logout(self):
        if messagebox.askyesno("Выход", "Завершить сеанс?"):
            self.root.destroy()
            LoginWindow("root", lambda e: MainWindow(e))
    
    def _trigger_red_alert(self):
        """Активирует красный режим"""
        for color in ["text", "text_success", "text_warning", "text_error", "text_user", "text_ai"]:
            COLORS[color] = COLORS["text_error"]
        self._log("🔴", "РЕЖИМ ПАНИКИ АКТИВИРОВАН! Вся тема теперь красная.", "sys")
        # Перерисовка (упрощённо)
        self.chat_log.config(fg=COLORS["text_error"])


