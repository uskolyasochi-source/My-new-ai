# ==== СИСТЕМА ЛИЦЕНЗИРОВАНИЯ ====

def generate_request_code(email: str) -> str:
    """Генерирует код запроса для отправки администратору"""
    raw = f"{email.strip().lower()}|{SECRET_SALT}"
    hash_val = hashlib.sha256(raw.encode()).hexdigest()
    code = base64.b64encode(hash_val.encode()).decode()[:20]
    return f"REQ-{code}"


def generate_access_key(request_code: str) -> str:
    """[ADMIN] Генерирует ключ доступа из кода запроса"""
    clean = request_code.replace("REQ-", "").strip()
    raw = f"{clean}|ADMIN_APPROVED|{SECRET_SALT}"
    hash_val = hashlib.md5(raw.encode()).hexdigest()
    k1, k2, k3 = hash_val[:8].upper(), hash_val[8:12].upper(), hash_val[12:16].upper()
    return f"KEY-{k1}-{k2}-{k3}"


def validate_license(email: str, request_code: str, access_key: str) -> Tuple[bool, str]:
    """Проверяет лицензию. Возвращает (успех, сообщение)"""
    if generate_request_code(email) != request_code:
        return False, "❌ Request Code не соответствует Email"
    try:
        parts = access_key.strip().split('-')
        if len(parts) != 4 or parts[0] != 'KEY':
            return False, "❌ Неверный формат ключа"
        clean = request_code.replace("REQ-", "").strip()
        raw = f"{clean}|ADMIN_APPROVED|{SECRET_SALT}"
        expected = hashlib.md5(raw.encode()).hexdigest().lower()
        user_hash = (parts[1] + parts[2] + parts[3]).lower()
        return (True, "✅ Доступ разрешён") if user_hash == expected else (False, "❌ Неверный Access Key")
    except Exception as e:
        return False, f"❌ Ошибка: {str(e)}"


def save_license(email: str, req: str, key: str) -> bool:
    try:
        os.makedirs(DATA_DIR, exist_ok=True)
        with open(LICENSE_FILE, "w", encoding="utf-8") as f:
            json.dump({"email": email, "req_code": req, "access_key": key}, f, ensure_ascii=False, indent=2)
        return True
    except: return False


def load_license() -> Optional[Dict[str, str]]:
    if os.path.exists(LICENSE_FILE):
        try:
            with open(LICENSE_FILE, "r", encoding="utf-8") as f:
                return json.load(f)
        except: pass
    return None


# ==== ЯДРО ИИ ====

class MultiAIBrain:
    """Интеллект бота: паттерны, контекст, fuzzy-поиск"""
    
    def __init__(self):
        self.context: List[Dict[str, str]] = self._load_json(MEMORY_FILE, [])
        self.patterns: List[Dict[str, Any]] = self._build_patterns()
    
    def _load_json(self, path: str, default: Any = None) -> Any:
        if default is None: default = []
        if not os.path.exists(path): return default
        try:
            with open(path, "r", encoding="utf-8") as f:
                data = json.load(f)
            return data if isinstance(data, (list, dict)) else default
        except: return default
    
    def _save_json(self, path: str,  Any) -> bool:
        try:
            os.makedirs(os.path.dirname(path), exist_ok=True)
            with open(path, "w", encoding="utf-8") as f:
                json.dump(data, f, ensure_ascii=False, indent=2)
            return True
        except: return False
    
    def _build_patterns(self) -> List[Dict[str, Any]]:
        """Встроенные ответы"""
        return [
            {"keywords": ["привет", "hi", "hello", "здравствуй", "йо"], "answer": "Привет! Система защищена. Готов к работе. 🤖"},
            {"keywords": ["как дела", "что нового", "как сам"], "answer": "Все системы в норме. Авторизация подтверждена. А у тебя как?"},
            {"keywords": ["кто ты", "что ты", "ты кто"], "answer": f"Я {APP_NAME} v{VERSION} — графический ИИ с защитой доступа и обучением."},
            {"keywords": ["помощь", "help", "что умеешь"], "answer": "Я умею:\n• Вести диалог с учётом контекста\n• Понимать опечатки (fuzzy matching)\n• Анализировать тональность текста\n• Обучаться новым фразам через вкладку 'Train AI'"},
            {"keywords": ["пока", "до свидания", "выход"], "answer": "Пока! Не забывай заглядывать — я сохраняю всё, чему ты меня научил. 👋"},
            {"keywords": ["спасибо", "благодарю", "респект", "круто"], "answer": "Пожалуйста! Стараюсь становиться умнее с каждым диалогом. 🚀"},
            {"keywords": ["расскажи анекдот", "шутка", "пошути"], "answer": "Почему программисты путают Хэллоуин и Рождество?\nПотому что Oct 31 == Dec 25 🎃🎄"},
            {"keywords": ["kill.os", "red alert", "panic"], "answer": "🔴 РЕЖИМ ПАНИКИ! (шутка, но тема стала красной)"},
        ] + self._load_json(KNOWLEDGE_FILE, [])
    
    def _analyze_sentiment(self, text: str) -> str:
        pos = ["хорошо", "отлично", "супер", "рад", "люблю", "класс", "круто", "весело"]
        neg = ["плохо", "ужас", "грустно", "зло", "ненавижу", "ошибка", "боль", "скучно"]
        t = text.lower()
        p, n = sum(1 for w in pos if w in t), sum(1 for w in neg if w in t)
        return "позитивный 😊" if p > n else "негативный 😔" if n > p else "нейтральный 😐"
    
    def get_response(self, user_text: str) -> str:
        text = user_text.strip()
        if not text: return "..."
        text_low = text.lower()
        
        # Поиск по паттернам (точный + fuzzy)
        best_ans, best_ratio = None, 0.0
        for pat in self.patterns:
            for kw in pat.get("keywords", []):
                if kw in text_low: return pat["answer"]
                ratio = difflib.SequenceMatcher(None, text_low, kw).ratio()
                if ratio > best_ratio and ratio >= FUZZY_THRESHOLD:
                    best_ratio, best_ans = ratio, pat["answer"]
        if best_ans: return best_ans
        
        # Контекстные вопросы
        if self.context:
            last = self.context[-1]
            if any(q in text_low for q in ["почему", "зачем", "причина"]) and len(text.split()) < 5:
                return f"🔍 Контекст: ранее ты спросил «{last['user']}». Мой ответ: «{last['ai']}». Уточни?"
            if any(q in text_low for q in ["повтори", "ещё раз", "напомни"]):
                return f"🔁 Я сказал: {last['ai']}"
        
        # Fallback: анализ
        sent = self._analyze_sentiment(text)
        return f"🤔 Не нашёл ответа, но проанализировал:\n• Тональность: {sent}\n• Символов: {len(text)}, Слов: {len(text.split())}\n• Время: {datetime.now().strftime('%H:%M')}\n\nПопробуй перефразировать или обучи меня во вкладке 'Train AI'!"
    
    def train(self, keywords: str, answer: str) -> bool:
        kw_list = [k.strip().lower() for k in keywords.split(",") if k.strip()]
        if not kw_list or not answer.strip(): return False
        knowledge = self._load_json(KNOWLEDGE_FILE, [])
        knowledge.append({"keywords": kw_list, "answer": answer.strip()})
        if self._save_json(KNOWLEDGE_FILE, knowledge):
            self.patterns = self._build_patterns()
            return True
        return False
    
    def add_context(self, user: str, ai: str):
        self.context.append({"user": user, "ai": ai})
        if len(self.context) > CONTEXT_DEPTH: self.context = self.context[-CONTEXT_DEPTH:]
        self._save_json(MEMORY_FILE, self.context)
    
    def clear_context(self):
        self.context = []
        self._save_json(MEMORY_FILE, self.context)


