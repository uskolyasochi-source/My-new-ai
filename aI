    def _update_req(self):
        email = self.email_ent.get()
        self.req_lbl.config(text=generate_request_code(email) if "@" in email else "...введи email...")
    
    def _login(self):
        email, key = self.email_ent.get(), self.key_ent.get()
        if not email or not key:
            messagebox.showerror("Ошибка", "Заполни все поля!")
            return
        req = generate_request_code(email)
        ok, msg = validate_license(email, req, key)
        if ok:
            if save_license(email, req, key):
                messagebox.showinfo("Успех", msg)
                self.win.destroy()
                self.on_success(email)
            else:
                messagebox.showerror("Ошибка", "Не удалось сохранить лицензию")
        else:
            messagebox.showerror("Отказано", f"{msg}\n\nТвой Request Code:\n{req}")
    
    def _open_admin_panel(self):
        AdminPanel(self.win)


