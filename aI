        btn_f.pack(pady=5)
        tk.Button(btn_f, text="🔑 Сгенерировать", command=self._generate, bg=COLORS["btn_success"], fg="white", cursor="hand2").pack(side="left", padx=5)
        tk.Button(btn_f, text="✕ Закрыть", command=self.win.destroy, bg=COLORS["btn_danger"], fg="white", cursor="hand2").pack(side="left", padx=5)
    
    def _generate(self):
        code = self.code_ent.get().strip()
        if not code.startswith("REQ-"):
            self.result.config(text="❌ Код должен начинаться с REQ-", fg=COLORS["text_error"])
            return
        key = generate_access_key(code)
        self.result.config(text=f"✅ Готовый ключ:\n{key}", fg=COLORS["text_success"])
        # Копируем в буфер
        self.win.clipboard_clear()
        self.win.clipboard_append(key)
        messagebox.showinfo("Успех", "Ключ сгенерирован и скопирован в буфер обмена!")


